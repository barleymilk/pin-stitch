{
  "name": "pin-stitch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prisma:validate": "prisma validate --schema apps/api/prisma/schema.prisma",
    "prisma:format": "prisma format --schema apps/api/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema apps/api/prisma/schema.prisma",
    "dev:api": "npm --workspace @pin-stitch/api run dev",
    "dev:web": "npm --workspace @pin-stitch/web run dev"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.2"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  }
}
